# =========================================================================
# CrystalCastle - Official .dockerignore Template (2026)
# =========================================================================

# --- Git & System Files ---
.git
.github
.gitignore
*.md
LICENSE
CHANGELOG.md

# --- Development & IDE Settings ---
.vscode
.idea
.pnp
.pnp.js
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.editorconfig

# --- Dependencies & Package Manager Locks ---
# (ปล่อยให้ Docker เป็นคนสั่ง npm install / yarn install ภายใน Container เอง)
node_modules
/Frontend/node_modules
/crystalcastle-dashboard/node_modules
jspm_packages
.npm
.eslintcache
.prettiercache

# --- Build Outputs, Artifacts & Cache ---
dist
build
out
.next
.nuxt
.cache
artifacts
/artifacts
.template-docs
doc
docs
knowledge-base
Quiz
Image

# --- Logs and Runtime Files ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.logs
/notify_system/*.log

# --- Testing & Coverage ---
coverage
.nyc_output
__tests__
test
tests
.jest

# --- Environment Variables & Secrets (CRITICAL SECURITY) ---
# ห้ามหลุดเข้าไปใน Docker Image เด็ดขาดเพื่อความปลอดภัยของ API Keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example
env.example.json
/version

# --- Docker Specifics ---
.dockerignore
Dockerfile
docker-compose.yml

