# ============================
# Crystal Castle – Environment
# ============================

# 🔑 Supabase (จำเป็นสำหรับการเชื่อมต่อฐานข้อมูลและ storage)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here        # URL ของ Supabase project
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key   # Public anon key สำหรับ client

# 🤖 AI Prompt/Caption Generation
GROQ_API_KEY=your_groq_api_key                         # ใช้ Groq (Llama 3.3) สำหรับ AI prompt/caption

# 🎬 Video Engine Keys (ต้องมีอย่างน้อยหนึ่ง)
FAL_KEY=your_fal_key                                   # ใช้ FAL Kling สำหรับ video generation
MAGIC_HOUR_API_KEY=your_magic_hour_key                 # ใช้ Magic Hour engine
RUNWAYML_API_SECRET=your_runway_secret                 # ใช้ RunwayML API
PIKA_API_KEY=your_pika_key                             # ใช้ Pika API
NEXA_API_KEY=your_nexa_key                             # ใช้ Nexa API
WAVESPEED_API_KEY=your_wavespeed_key                   # ใช้ Wavespeed API

# 🌐 Optional Fallback AI
GEMINI_API_KEY=your_gemini_key                         # ใช้ Gemini เมื่อ Groq ล้มเหลว

# 🔒 Security (server-side only – ห้าม commit ไป client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key        # Service role key สำหรับ API routes ฝั่ง server

# 🧪 Development / Mock Mode
NEXT_PUBLIC_USE_MOCK=true                              # เปิด mock mode เพื่อทดสอบโดยไม่ใช้เครดิตจริง