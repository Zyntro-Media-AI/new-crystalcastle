# =========================================================================
# 🏰 CRYSTAL CASTLE AI VIDEO STUDIO - ENVIRONMENT VARIABLES TEMPLATE
# =========================================================================
# คำแนะนำ: คัดลอกไฟล์นี้ไปสร้างเป็นไฟล์ `.env` แล้วเติมค่าจริง ห้าม Commit ไฟล์ `.env` ขึ้น GitHubเด็ดขาด

# -------------------------------------------------------------------------
# 🔌 BACKEND & CORE SERVICES (Server-Side Only - ปลอดภัยสูง ห้ามหลุดไปหน้าบ้าน)
# -------------------------------------------------------------------------

# 🗄️ Database Configurations
DATABASE_URL=postgresql://crystal:crystalpass@db:5432/crystalcastle
REDIS_URL=redis://redis:6379/0

# 🔒 Security & API Gateway Authentication
X_API_KEY=local-dev-key
HEALTH_API_SECRET=your_super_secret_token_here
# ALLOWED_HEALTH_PROVIDER_IP=xxx.xxx.xxx.xxx

# 🤖 Core AI Engine & Endpoints
GROQ_API_KEY=your_groq_api_key_for_backend
AI_ENDPOINT=http://mock_ai:8000/generate
GEMINI_API_KEY=your_gemini_key_as_fallback

# 🔑 Supabase Admin Privileges
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -------------------------------------------------------------------------
# 🎬 VIDEO GENERATION ENGINES (Server-Side Credits & Keys)
# -------------------------------------------------------------------------
FAL_KEY=your_fal_key                                   # สำหรับใช้งาน FAL Kling Engine
MAGIC_HOUR_API_KEY=your_magic_hour_key                 # สำหรับใช้งาน Magic Hour Engine
RUNWAYML_API_SECRET=your_runway_secret                 # สำหรับใช้งาน RunwayML Engine
PIKA_API_KEY=your_pika_key                             # สำหรับใช้งาน Pika Engine
NEXA_API_KEY=your_nexa_key                             # สำหรับใช้งาน Nexa Engine
WAVESPEED_API_KEY=your_wavespeed_key                   # สำหรับใช้งาน Wavespeed Engine

# -------------------------------------------------------------------------
# 🌐 FRONTEND & NEXT.JS CLIENT (เปิดเผยต่อ Client-Side ได้ผ่านคำนำหน้า NEXT_PUBLIC_)
# -------------------------------------------------------------------------

# 🗺️ Supabase Client Connections
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 🧪 System Configurations / Debug Mode
NEXT_PUBLIC_USE_MOCK=true                              # เปิด True เพื่อทดสอบระบบแบบจำลอง (ไม่เสียเครดิตจริง)


# 🌐 Optional Fallback AI & Extras
GEMINI_API_KEY=your_gemini_key_here
HF_API_TOKEN=your_huggingface_token_here
COHERE_API_KEY=your_cohere_key_here
