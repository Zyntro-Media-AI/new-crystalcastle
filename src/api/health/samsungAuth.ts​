// src/api/health/samsungAuth.ts const SAMSUNG_AUTH_URL = "https://us.shealth.samsung.com/auth/oauth2/token";  export const getSamsungToken = async (code: string) => {   const res = await fetch(SAMSUNG_AUTH_URL, {     method: "POST",     headers: { "Content-Type": "application/x-www-form-urlencoded" },     body: new URLSearchParams({       grant_type: "authorization_code",       client_id: import.meta.env.VITE_SAMSUNG_CLIENT_ID,       client_secret: import.meta.env.VITE_SAMSUNG_CLIENT_SECRET,       code,     }),   });   return res.json(); // { access_token, refresh_token } };