{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).(jpg|jpeg|png|gif|webp|svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "functions": {
    "api/upload.js": { "maxDuration": 10 },
    "api/video.js": { "maxDuration": 10 },
    "api/magichour.js": { "maxDuration": 10 },
    "api/prompt.js": { "maxDuration": 10 },
    "api/post.js": { "maxDuration": 10 },
    "api/get-logs.js": { "maxDuration": 10 },
    "api/artifacts.js": { "maxDuration": 10 }
  }
}