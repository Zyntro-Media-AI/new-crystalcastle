│   ├── ProductUpload.tsx       # PascalCase for React components
│   ├── video-generator.ts      # kebab-case for utilities
│   └── use-product-form.ts    # kebab-case for hooks
├── lib/
│   ├── config.ts
│   └── api-handler.ts
├── pages/
│   └── api/
│       └── generate-video.ts   # kebab-case for API routes

❌ INCORRECT:
├── components/
│   ├── productUpload.tsx       # Wrong casing
│   ├── VideoGenerator.tsx      # Should be PascalCase, not random
│   └── Use_Product_Form.ts     # No underscores or random case
├── "Pull Request Template.pdf" # No spaces in filenames
