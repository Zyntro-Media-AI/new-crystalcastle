6.4 Pre-Commit Security Check

```bash
#!/bin/bash
# .git/hooks/pre-commit
# Automated security check before every commit

echo "🔍 Running security checks..."

# Check for hardcoded API keys
if grep -r -E "sk-[a-zA-Z0-9]{20,}" --include="*.ts" --include="*.js" --include="*.tsx" --include="*.jsx" .; then
  echo "❌ ERROR: Hardcoded API key found!"
  echo "Remove the key and use environment variables instead."
  exit 1
fi

# Check for NEXT_PUBLIC_ with sensitive keys
if grep -r -E "NEXT_PUBLIC_.*(KEY|SECRET|TOKEN)" --include="*.ts" --include="*.js" .; then
  echo "⚠️  WARNING: NEXT_PUBLIC_ used with potential secret!"
  echo "Review if this variable should be exposed to the client."
fi

# Check for console.log in production code
if grep -r -E "console\.(log|warn)" --include="*.ts" --include="*.js" pages/ app/; then
  echo "⚠️  WARNING: console.log statements found in production code."
  echo "Consider using the logger utility instead."
fi

echo "✅ Security checks passed!"
```

