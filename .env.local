# 🔑 Supabase Project URL (ใช้สำหรับเชื่อมต่อ Supabase Database)
# Supabase Project URL (connect to Supabase Database)
NEXT_PUBLIC_SUPABASE_URL=<your-supabase-url>

# 🔑 Supabase Anonymous Key (ใช้ฝั่ง client, ไม่ควรใช้ใน server)
# Supabase Anonymous Key (client-side only, not for server)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# 🔑 Supabase Service Role Key (ใช้ฝั่ง server, ต้องเก็บเป็นความลับ)
# Supabase Service Role Key (server-side only, keep secret)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# 🔑 GROQ API Key (ใช้สำหรับ AI pipeline integration)
# GROQ API Key (for AI pipeline integration)
GROQ_API_KEY=<your-groq-api-key>

# 🔑 Gemini API Key (ใช้สำหรับ Google Gemini AI integration)
# Gemini API Key (for Google Gemini AI integration)
GEMINI_API_KEY=<your-gemini-api-key>

# 🔑 OpenAI API Key (ใช้สำหรับ AI model integration)
# OpenAI API Key (for AI model integration)
OPENAI_API_KEY=<your-openai-api-key>

# 🔑 Telegram Bot Token (ใช้สำหรับส่ง alert/notification)
# Telegram Bot Token (for sending alerts/notifications)
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
+SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

