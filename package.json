{
  "name": "crystalcastle",
  "version": "1.5.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",

    "build": "next build",
    "start": "next start",

    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --fix",

    "format": "prettier --write .",
    "format:check": "prettier --check .",

    "type-check": "tsc --noEmit",

    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",

    "clean": "rm -rf .next node_modules coverage",

    "analyze": "ANALYZE=true next build",

    "check": "pnpm lint && pnpm type-check && pnpm test",

    "prepare": "husky install"
  },
  "dependencies": {
    "next": "^14.2.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",

    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.1",

    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",

    "zod": "^3.24.1",

    "clsx": "^2.1.1",

    "lucide-react": "^0.468.0",

    "ai": "^4.1.16",

    "openai": "^4.76.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",

    "typescript": "^5.7.2",

    "eslint": "^9.17.0",
    "eslint-config-next": "^14.2.25",
    "postcss": "^8.5.10",
"next": ">=15.5.15",,
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "eslint-config-prettier": "^9.1.0",

    "prettier": "^3.4.2",

    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.20",

    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8",

    "@testing-library/react": "^16.1.0",
    "@testing-library/jest-dom": "^6.6.3",

    "husky": "^9.1.7",

    "lint-staged": "^15.2.11"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}